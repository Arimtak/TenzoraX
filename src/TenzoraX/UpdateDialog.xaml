<Window x:Class="TenzoraX.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TenzoraX" Height="260" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0F0F15" Foreground="White"
        WindowStyle="None" AllowsTransparency="True"
        MouseDown="Window_MouseDown">
    <Border CornerRadius="12" Background="#0F0F15" BorderBrush="#1E1E28" BorderThickness="1" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="TenzoraX" FontWeight="Bold" FontSize="16" Foreground="#00D2FF" Margin="0,0,0,8"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock x:Name="TxtUpdateMsg" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,10" Foreground="White"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Installiert:" FontSize="11" Foreground="#888" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtInstalled" Grid.Column="1" FontSize="11" Foreground="White"/>
                </Grid>
                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Neu:" FontSize="11" Foreground="#888" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TxtNewVersion" Grid.Column="1" FontSize="11" Foreground="#10B981" FontWeight="Bold"/>
                </Grid>

                <!-- Download progress section (hidden initially) -->
                <Border x:Name="PanelProgress" Visibility="Collapsed" Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TxtProgressStatus" Text="Update wird heruntergeladen..." FontSize="11" Foreground="#94A3B8" Margin="0,0,0,6"/>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100" Value="0"
                                         Foreground="#00D2FF" Background="#2D2D3A" BorderThickness="0" Margin="0,0,8,0"/>
                            <TextBlock x:Name="TxtProgressPct" Grid.Column="1" Text="0 %" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button x:Name="BtnUpdateLater" Content="Später" Click="BtnLater_Click" Width="80" Height="30" FontSize="11" Background="#1E1E28" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Foreground="White" Margin="0,0,8,0"/>
                <Button x:Name="BtnUpdateNow" Content="Jetzt aktualisieren" Click="BtnUpdate_Click" Width="140" Height="30" FontSize="11" FontWeight="Bold" Background="#0F2C3A" BorderBrush="#00D2FF" BorderThickness="1" Foreground="#00D2FF"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
