<Window x:Class="TenzoraX.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ShowActivated="False"
        Focusable="False" ResizeMode="NoResize" Cursor="SizeAll"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="Manual">
    <Window.RenderTransform>
        <TranslateTransform x:Name="SlideTransform"/>
    </Window.RenderTransform>
    <Border Background="#1A1A24" BorderBrush="#2A2A3A" BorderThickness="1" CornerRadius="12" Padding="20,14,20,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="⌨" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TxtCombo" FontWeight="SemiBold" FontSize="15" Foreground="#E0E0E0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="→" FontSize="16" Foreground="#10B981" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtAction" FontWeight="Bold" FontSize="15" Foreground="#10B981" Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <Border x:Name="ProgressBar" Grid.Row="2" Height="3" Background="#10B981" CornerRadius="1.5" Margin="0,10,0,0" HorizontalAlignment="Left" Width="320"/>
        </Grid>
    </Border>
</Window>
