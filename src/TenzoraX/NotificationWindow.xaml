<Window x:Class="TenzoraX.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ShowActivated="False"
        Focusable="False" ResizeMode="NoResize"
        Width="280" SizeToContent="Height"
        WindowStartupLocation="Manual">
    <Window.RenderTransform>
        <TranslateTransform x:Name="SlideTransform"/>
    </Window.RenderTransform>
    <Border Background="#1A1A24" BorderBrush="#2A2A3A" BorderThickness="1" CornerRadius="10" Padding="16,12,16,10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="TxtCombo" FontWeight="SemiBold" FontSize="13" Foreground="#E0E0E0"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="→" FontSize="14" Foreground="#10B981" FontWeight="Bold"/>
                <TextBlock x:Name="TxtAction" FontWeight="Bold" FontSize="13" Foreground="#10B981" Margin="8,0,0,0"/>
            </StackPanel>
            <Border x:Name="ProgressBar" Grid.Row="2" Height="2" Background="#10B981" CornerRadius="1" Margin="0,8,0,0" HorizontalAlignment="Left" Width="248"/>
        </Grid>
    </Border>
</Window>
