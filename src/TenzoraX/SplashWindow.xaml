<Window x:Class="TenzoraX.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="" Height="280" Width="420"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F12" Foreground="White"
        AllowsTransparency="False" Topmost="True"
        ShowInTaskbar="False">
    <Border CornerRadius="12" Background="#16161E" BorderBrush="#2D2D3D" BorderThickness="1" Margin="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="TenzoraX" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#E2E8F0"/>
                <TextBlock Text="Controller Mapping" FontSize="12" HorizontalAlignment="Center" Foreground="#94A3B8" Margin="0,6,0,0"/>

                <Border Width="64" Height="4" CornerRadius="2" Background="#2D2D3D" Margin="0,24,0,0">
                    <Border x:Name="AccentBar" Width="0" Height="4" CornerRadius="2" Background="#00D2FF" HorizontalAlignment="Left"/>
                </Border>

                <TextBlock x:Name="TxtStatus" Text="Programm wird geladen..." FontSize="13"
                           HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="#94A3B8"/>

                <ProgressBar x:Name="ProgressBar" Width="320" Height="4" Margin="0,12,0,0"
                             Minimum="0" Maximum="100" Value="0"
                             Foreground="#00D2FF" Background="#2D2D3A" BorderThickness="0"/>
            </StackPanel>

            <TextBlock Grid.Row="1" x:Name="TxtVersion" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,0,0,8" Foreground="#555"/>
        </Grid>
    </Border>
</Window>
